# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
# Step4 脚本建议配置 service role（USER_LIVE 读写）
SUPABASE_SERVICE_ROLE_KEY=

# Feishu Webhook (Optional)
FEISHU_WEBHOOK_URL=

# Tushare Pro (Optional, for data source)
TUSHARE_TOKEN=

# LLM (for step3 / step4)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Step4 private portfolio delivery
# 定时任务只执行该用户（必须是 Supabase Auth 的 user_id）
SUPABASE_USER_ID=
TG_BOT_TOKEN=
TG_CHAT_ID=
# 可选兜底：若 USER_LIVE:<user_id> 不可用则使用此 JSON
MY_PORTFOLIO_STATE=

# Step3 RAG 防雷（可选，未配置 key 自动跳过）
RAG_VETO_ENABLED=1
TAVILY_API_KEY=
RAG_NEGATIVE_KEYWORDS=
RAG_TIMEOUT=12
RAG_MAX_WORKERS=6
RAG_NEWS_LOOKBACK_DAYS=7
RAG_MAX_RESULTS=5

# Step3 候选输入上限（0=不限制，全量输入 AI）
STEP3_MAX_AI_INPUT=0
STEP3_ENABLE_COMPRESSION=1
STEP3_MAX_PER_INDUSTRY=5
STEP3_ENABLE_RAG_VETO=1

# Step4 OMS 风控增强
STEP4_ATR_PERIOD=14
STEP4_ATR_MULTIPLIER=2.0
STEP4_ATR_SLIPPAGE_FACTOR=0.25
STEP4_MAX_WORKERS=8
# 买入动作(PROBE/ATTACK)硬止损线（实盘默认锁死 -9%）
STEP4_BUY_HARD_STOP_ENABLED=1
STEP4_BUY_HARD_STOP_PCT=9.0
STEP4_BUY_STOP_MODE=floor
# 持仓天数硬规则：满 N 交易日强制 EXIT
STEP4_FORCE_MAX_HOLD_EXIT=1
STEP4_MAX_HOLD_DAYS=5
# 单票资金上限（满足“Top3 单票最多 20%~30%”的约束）
STEP4_PROBE_BUDGET_LIMIT=0.10
STEP4_ATTACK_BUDGET_LIMIT=0.20

# Funnel 并发模式与性能参数
FUNNEL_TRADING_DAYS=500
FUNNEL_EXECUTOR_MODE=process
FUNNEL_MAX_WORKERS=8
FUNNEL_BATCH_SIZE=250
FUNNEL_BATCH_SLEEP=2
FUNNEL_BATCH_TIMEOUT=420
FUNNEL_FETCH_TIMEOUT=45
FUNNEL_SOCKET_TIMEOUT=20
FUNNEL_PANIC_SNAPSHOT_TIMEOUT=20
FUNNEL_FETCH_RETRIES=2
FUNNEL_RETRY_BASE_DELAY=1.0

# Funnel 真实策略参数（FUNNEL_CFG_* -> FunnelConfig）
FUNNEL_CFG_MIN_MARKET_CAP_YI=20.0
FUNNEL_CFG_MIN_AVG_AMOUNT_WAN=5000.0
FUNNEL_CFG_AMOUNT_AVG_WINDOW=20
FUNNEL_CFG_MA_SHORT=50
FUNNEL_CFG_MA_LONG=200
FUNNEL_CFG_MA_HOLD=20
FUNNEL_CFG_BENCH_DROP_DAYS=3
FUNNEL_CFG_BENCH_DROP_THRESHOLD=-2.0
FUNNEL_CFG_RS_WINDOW_LONG=10
FUNNEL_CFG_RS_WINDOW_SHORT=3
FUNNEL_CFG_RS_MIN_LONG=0.0
FUNNEL_CFG_RS_MIN_SHORT=0.0
FUNNEL_CFG_ENABLE_RS_FILTER=1
FUNNEL_CFG_ENABLE_RPS_FILTER=1
FUNNEL_CFG_RPS_WINDOW_FAST=50
FUNNEL_CFG_RPS_WINDOW_SLOW=120
FUNNEL_CFG_RPS_FAST_MIN=75.0
FUNNEL_CFG_RPS_SLOW_MIN=70.0
FUNNEL_CFG_REQUIRE_BENCH_LATEST_ALIGNMENT=0
FUNNEL_CFG_TOP_N_SECTORS=3
FUNNEL_CFG_SPRING_SUPPORT_WINDOW=60
FUNNEL_CFG_SPRING_VOL_RATIO=1.0
FUNNEL_CFG_SPRING_TR_MAX_RANGE_PCT=30.0
FUNNEL_CFG_SPRING_TR_MAX_DRIFT_PCT=12.0
FUNNEL_CFG_LPS_LOOKBACK=3
FUNNEL_CFG_LPS_MA=20
FUNNEL_CFG_LPS_MA_TOLERANCE=0.02
FUNNEL_CFG_LPS_VOL_DRY_RATIO=0.35
FUNNEL_CFG_LPS_VOL_REF_WINDOW=60
FUNNEL_CFG_EVR_LOOKBACK=3
FUNNEL_CFG_EVR_VOL_RATIO=1.6
FUNNEL_CFG_EVR_VOL_WINDOW=20
FUNNEL_CFG_EVR_MAX_DROP=2.0
FUNNEL_CFG_EVR_MAX_BIAS_200=40.0
FUNNEL_CFG_EVR_CONFIRM_DAYS=1
FUNNEL_CFG_EVR_CONFIRM_ALLOW_BREAK_PCT=0.0
FUNNEL_CFG_ENABLE_EVR_TRIGGER=0

# Step0: 大盘广度与水温
FUNNEL_BREADTH_MA_WINDOW=20
FUNNEL_BREADTH_RISK_OFF_PCT=20.0
FUNNEL_BREADTH_RISK_ON_PCT=60.0
FUNNEL_BREADTH_RISK_ON_DELTA=0.0
FUNNEL_BREADTH_CLIFF_DROP_PCT=-10.0

# 定时任务交易日口径（北京时间）：
# 17:00-23:59 -> 目标日 T
# 00:00-16:59 -> 目标日 T-1

# 交易日历与截面日期严格对齐
ALLOW_APPROX_TRADE_CALENDAR=0
ENFORCE_TARGET_TRADE_DATE=0

# 日线延迟时的实时快照补偿（默认开启）
SPOT_SNAPSHOT_TTL_SECONDS=20
FUNNEL_ENABLE_SPOT_PATCH=1
FUNNEL_SPOT_PATCH_RETRIES=2
FUNNEL_SPOT_PATCH_SLEEP=0.2
STEP3_ENABLE_SPOT_PATCH=1
STEP3_SPOT_PATCH_RETRIES=2
STEP3_SPOT_PATCH_SLEEP=0.2
STEP4_ENABLE_SPOT_PATCH=1
STEP4_SPOT_PATCH_RETRIES=2
STEP4_SPOT_PATCH_SLEEP=0.3
