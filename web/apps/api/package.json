{
  "name": "@wyckoff/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:debug": "wrangler dev --inspector-port 9229",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit",
    "test": "vitest run",
